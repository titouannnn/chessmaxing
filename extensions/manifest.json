{
  "manifest_version": 3,
  "name": "chessmaxing extensions",
  "version": "1.0",
  "description": "Export a PGN game from chess.com to a analysis board online free.",

  "icons": {
    "48": "logo.png"
  },

  "permissions": [
    "scripting",
    "activeTab",
    "storage"
  ],

  "host_permissions": [
    "https://www.chess.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": ["content-bridge.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": "logo.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "chessmaxer@titouan.me"
    }
  }
}
